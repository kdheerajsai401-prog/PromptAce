# PromptAce — Environment Variables
# Copy this file to .env.local and fill in your values
# Never commit .env.local — it's already in .gitignore

# Required: Anthropic API key (get yours at console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for Phase 2 (Auth): Clerk keys (get yours at clerk.com)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Required for Phase 2 (Database): Neon connection string (get yours at neon.tech)
# DATABASE_URL=

# Required for Phase 3 (Payments): Stripe keys (get yours at dashboard.stripe.com)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
